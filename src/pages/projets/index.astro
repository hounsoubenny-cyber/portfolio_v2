---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projets');

// Sort projects by date_debut descending
const sortedProjects = projects.sort(
  (a, b) => new Date(b.data.date_debut).getTime() - new Date(a.data.date_debut).getTime()
);

// Collect all unique tags for filter suggestions
const allTags = Array.from(
  new Set(sortedProjects.flatMap(p => p.data.tags))
);
---

<Layout 
  title="Mes Projets" 
  description="Découvrez l'ensemble des projets techniques de Benny Samuel HOUNSOU. Systèmes RAG hors-ligne, classifieurs d'URLs de phishing, outils de détection réseau (IDS) et portails documentaires sécurisés."
>
  <div class="max-w-6xl mx-auto px-6 py-12 md:py-20 flex flex-col gap-12 animate-fadeIn">
    <!-- Page Header -->
    <div class="flex flex-col gap-3">
      <span class="font-mono text-xs font-bold uppercase tracking-widest text-primary">
        <span class="lang-fr">Réalisations</span>
        <span class="lang-en">Achievements</span>
      </span>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-text-main font-heading">
        <span class="lang-fr">Mes Travaux & Projets</span>
        <span class="lang-en">My Works & Projects</span>
      </h1>
      <p class="text-base text-text-sub max-w-xl font-sans">
        <span class="lang-fr">Une galerie complète de mes réalisations techniques en Intelligence Artificielle, Cybersécurité et développement fullstack d'applications.</span>
        <span class="lang-en">A complete gallery of my technical achievements in Artificial Intelligence, Cybersecurity, and full-stack application development.</span>
      </p>
    </div>

    <!-- Interactive Filter Group -->
    <div class="flex flex-wrap items-center gap-2 border-b border-border pb-6">
      <button 
        data-filter="all" 
        class="filter-btn px-4 py-2 text-xs font-mono font-bold uppercase rounded-xl border border-primary bg-primary text-white hover:shadow-md cursor-pointer transition-all duration-200"
      >
        <span class="lang-fr">Tous</span>
        <span class="lang-en">All</span>
      </button>
      {allTags.map(tag => (
        <button 
          data-filter={tag.toLowerCase()} 
          class="filter-btn px-4 py-2 text-xs font-mono font-bold uppercase rounded-xl border border-border bg-surface text-text-sub hover:border-primary hover:text-primary cursor-pointer transition-all duration-200"
        >
          {tag}
        </button>
      ))}
    </div>

    <!-- Projects Grid -->
    <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 transition-all duration-300">
      {sortedProjects.map(project => {
        // Collect tags lowercased for filter queries
        const filterClasses = project.data.tags.map(t => t.toLowerCase()).join('|||');
        
        return (
          <article 
            data-tags={filterClasses} 
            class="project-card group flex flex-col bg-surface border border-border rounded-3xl overflow-hidden shadow-sm card-hover transition-all duration-500 opacity-100 scale-100"
          >
            <!-- Cover Image -->
            <div class="relative aspect-[16/9] overflow-hidden border-b border-border">
              <img
                src={project.data.image_cover}
                alt={project.data.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>

            <div class="p-6 md:p-8 flex-grow flex flex-col justify-between gap-6">
              <div>
                <!-- Metadata Row -->
                <div class="flex items-center justify-between gap-2 font-mono text-[10px]">
                  <span class="text-text-sub font-bold">
                    <span class="lang-fr">
                      {new Date(project.data.date_debut).toLocaleDateString('fr-FR', { year: 'numeric', month: 'short' })} 
                      {project.data.date_fin ? ` - ${new Date(project.data.date_fin).toLocaleDateString('fr-FR', { year: 'numeric', month: 'short' })}` : " - En cours"}
                    </span>
                    <span class="lang-en">
                      {new Date(project.data.date_debut).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })} 
                      {project.data.date_fin ? ` - ${new Date(project.data.date_fin).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}` : " - In progress"}
                    </span>
                  </span>
                  
                  <span class={`px-2.5 py-0.5 rounded-full font-bold uppercase tracking-wide text-[9px] ${
                    project.data.status === 'terminé' ? 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400' :
                    project.data.status === 'en cours' ? 'bg-blue-500/10 text-blue-600 dark:text-blue-400' :
                    'bg-amber-500/10 text-amber-600'
                  }`}>
                    <span class="lang-fr">{project.data.status}</span>
                    <span class="lang-en">{project.data.status === 'terminé' ? 'completed' : project.data.status === 'en cours' ? 'in progress' : 'planned'}</span>
                  </span>
                </div>

                <!-- Title -->
                <h2 class="text-xl md:text-2xl font-bold text-text-main mt-4 tracking-tight font-heading">
                  {project.data.title}
                </h2>

                <!-- Short Description -->
                <p class="text-sm text-text-sub mt-2.5 leading-relaxed font-sans">
                  {project.data.description}
                </p>
              </div>

              <div>
                <!-- Technologies list -->
                <div class="flex flex-wrap gap-1.5 mt-2">
                  {project.data.stack.map(tech => (
                    <span class="text-[10px] font-mono bg-border/40 text-text-main px-2 py-0.5 rounded-md font-medium">
                      {tech}
                    </span>
                  ))}
                </div>

                <!-- Footer Buttons -->
                <div class="flex items-center justify-between border-t border-border pt-5 mt-6">
                  <a 
                    href={`/projets/${project.id}`} 
                    class="inline-flex items-center gap-1.5 text-xs font-bold text-primary hover:text-primary-hover uppercase tracking-wider group transition-colors"
                  >
                    <span class="lang-fr">Détails & Code</span>
                    <span class="lang-en">Details & Code</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                  </a>

                  <!-- Quick GitHub Link -->
                  {project.data.lien_github && (
                    <a 
                      href={project.data.lien_github} 
                      target="_blank" 
                      rel="noopener noreferrer" 
                      aria-label={`Code source pour ${project.data.title}`}
                      class="p-2 rounded-xl border border-border bg-surface hover:bg-border/40 transition-colors btn-hover"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-text-main" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                        <path d="M9 18c-4.51 2-5-2-7-2"></path>
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</Layout>

<script>
  // Dynamic client-side filtering script
  const filterButtons = document.querySelectorAll('.filter-btn');
  const projectCards = document.querySelectorAll('.project-card');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const selectedFilter = btn.getAttribute('data-filter') || 'all';

      // 1. Update Active state on buttons
      filterButtons.forEach(b => {
        b.classList.remove('bg-primary', 'text-white', 'border-primary');
        b.classList.add('bg-surface', 'text-text-sub', 'border-border');
      });
      btn.classList.add('bg-primary', 'text-white', 'border-primary');
      btn.classList.remove('bg-surface', 'text-text-sub', 'border-border');

      // 2. Hide / Show Cards with beautiful fade/scale transitions
      projectCards.forEach(card => {
        const cardTagsStr = card.getAttribute('data-tags') || '';
        const cardTags = cardTagsStr.split('|||');

        if (selectedFilter === 'all' || cardTags.includes(selectedFilter)) {
          card.classList.remove('hidden');
          // Add timeout to let display:block register before setting opacity
          setTimeout(() => {
            card.classList.remove('opacity-0', 'scale-95');
            card.classList.add('opacity-100', 'scale-100');
          }, 20);
        } else {
          card.classList.add('opacity-0', 'scale-95');
          card.classList.remove('opacity-100', 'scale-100');
          // Wait for transition before hiding completely from DOM layout
          setTimeout(() => {
            card.classList.add('hidden');
          }, 300);
        }
      });
    });
  });
</script>
