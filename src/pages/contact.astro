---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact" 
  description="Contactez Benny Samuel HOUNSOU. Disponible pour des missions de conseil, d'ingénierie en machine learning, de développement fullstack d'applications ou de solutions d'automatisation."
>
  <div class="max-w-5xl mx-auto px-6 py-12 md:py-20 flex flex-col gap-12 animate-fadeIn">
    <!-- Header -->
    <div class="flex flex-col gap-3">
      <span class="font-mono text-xs font-bold uppercase tracking-widest text-primary">Contact</span>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-text-main font-heading">
        <span class="lang-fr">Entrons en Relation</span>
        <span class="lang-en">Let's Connect</span>
      </h1>
      <p class="text-base text-text-sub max-w-xl font-sans">
        <span class="lang-fr">Une question technique, une proposition de collaboration ou besoin d'une expertise en automatisation et IA ? Écrivez-moi directement.</span>
        <span class="lang-en">A technical question, a collaboration proposal, or a need for automation and AI expertise? Write to me directly.</span>
      </p>
    </div>

    <!-- Contact Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      <!-- Left: Direct Details (4 columns) -->
      <div class="lg:col-span-4 flex flex-col gap-6">
        <h2 class="text-xl font-bold text-text-main font-heading pb-2 border-b border-border">
          <span class="lang-fr">Coordonnées Directes</span>
          <span class="lang-en">Direct Contact</span>
        </h2>

        <!-- Email Card -->
        <a 
          href="mailto:hounsoubenny.cyber@gmail.com" 
          class="flex items-center gap-4 p-4 rounded-2xl bg-surface border border-border card-hover group"
        >
          <span class="h-10 w-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
          </span>
          <div>
            <h3 class="text-xs font-mono uppercase font-bold text-text-main">E-mail</h3>
            <p class="text-xs sm:text-sm text-text-sub group-hover:text-primary transition-colors">
              hounsoubenny.cyber@gmail.com
            </p>
          </div>
        </a>

        <!-- WhatsApp Card -->
        <a 
          href="https://wa.me/22955931810" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="flex items-center gap-4 p-4 rounded-2xl bg-surface border border-border card-hover group"
        >
          <span class="h-10 w-10 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-500">
            <!-- Simple clean phone/message icon representing WhatsApp -->
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </span>
          <div>
            <h3 class="text-xs font-mono uppercase font-bold text-text-main">WhatsApp</h3>
            <p class="text-xs sm:text-sm text-text-sub group-hover:text-primary transition-colors">
              +229 55 93 18 10
            </p>
          </div>
        </a>

        <!-- LinkedIn Card -->
        <a 
          href="https://linkedin.com/in/benny-samuel-hounsou-631023249" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="flex items-center gap-4 p-4 rounded-2xl bg-surface border border-border card-hover group"
        >
          <span class="h-10 w-10 rounded-xl bg-blue-600/10 flex items-center justify-center text-blue-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect width="4" height="12" x="2" y="9"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </span>
          <div>
            <h3 class="text-xs font-mono uppercase font-bold text-text-main">LinkedIn</h3>
            <p class="text-xs sm:text-sm text-text-sub group-hover:text-primary transition-colors">
              benny-samuel-hounsou
            </p>
          </div>
        </a>

        <!-- GitHub Card -->
        <a 
          href="https://github.com/hounsoubenny-cyber" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="flex items-center gap-4 p-4 rounded-2xl bg-surface border border-border card-hover group"
        >
          <span class="h-10 w-10 rounded-xl bg-slate-500/10 flex items-center justify-center text-text-main">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
              <path d="M9 18c-4.51 2-5-2-7-2"></path>
            </svg>
          </span>
          <div>
            <h3 class="text-xs font-mono uppercase font-bold text-text-main">GitHub</h3>
            <p class="text-xs sm:text-sm text-text-sub group-hover:text-primary transition-colors">
              @hounsoubenny-cyber
            </p>
          </div>
        </a>
      </div>

      <!-- Right: Interactive Form (8 columns) -->
      <div class="lg:col-span-8 bg-surface border border-border rounded-3xl p-6 md:p-10 shadow-sm relative overflow-hidden">
        <h2 class="text-xl font-bold text-text-main font-heading pb-2 border-b border-border mb-6">
          <span class="lang-fr">Formulaire de Contact</span>
          <span class="lang-en">Contact Form</span>
        </h2>

        <!-- Interactive Contact Form -->
        <form id="contact-form" class="flex flex-col gap-5">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1.5">
              <label for="name" class="font-mono text-[10px] font-bold text-text-main uppercase tracking-wider">
                <span class="lang-fr">Votre Nom complet *</span>
                <span class="lang-en">Your Full Name *</span>
              </label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required 
                placeholder="Ex. Samuel Dupont" 
                class="w-full px-4 py-3 rounded-xl border border-border bg-bg/50 text-sm text-text-main"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="email" class="font-mono text-[10px] font-bold text-text-main uppercase tracking-wider">
                <span class="lang-fr">Votre Adresse E-mail *</span>
                <span class="lang-en">Your Email Address *</span>
              </label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                placeholder="Ex. samuel@entreprise.fr" 
                class="w-full px-4 py-3 rounded-xl border border-border bg-bg/50 text-sm text-text-main"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="subject" class="font-mono text-[10px] font-bold text-text-main uppercase tracking-wider">
              <span class="lang-fr">Sujet du Message *</span>
              <span class="lang-en">Message Subject *</span>
            </label>
            <input 
              type="text" 
              id="subject" 
              name="subject" 
              required 
              placeholder="Ex. Proposition de projet de Machine Learning" 
              class="w-full px-4 py-3 rounded-xl border border-border bg-bg/50 text-sm text-text-main"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="message" class="font-mono text-[10px] font-bold text-text-main uppercase tracking-wider">
              <span class="lang-fr">Message détaillé *</span>
              <span class="lang-en">Detailed Message *</span>
            </label>
            <textarea 
              id="message" 
              name="message" 
              required 
              rows="6" 
              placeholder="..." 
              class="w-full px-4 py-3 rounded-xl border border-border bg-bg/50 text-sm text-text-main resize-none"
            ></textarea>
          </div>

          <button 
            type="submit" 
            id="submit-btn"
            class="flex items-center justify-center gap-2 rounded-xl bg-primary px-6 py-4 text-sm font-bold text-white hover:bg-primary-hover shadow-md hover:shadow-lg hover:scale-[1.02] active:scale-95 transition-all cursor-pointer btn-hover"
          >
            <span id="btn-text-fr" class="lang-fr">Envoyer mon message</span>
            <span id="btn-text-en" class="lang-en">Send my message</span>
            <svg id="btn-icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" x2="11" y1="2" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </button>
        </form>

        <!-- Dynamic Success State Overlay -->
        <div 
          id="success-overlay" 
          class="absolute inset-0 bg-surface/95 backdrop-blur-md flex flex-col items-center justify-center text-center p-8 hidden transition-opacity duration-300 opacity-0"
        >
          <div class="h-16 w-16 bg-emerald-500/15 text-emerald-500 rounded-full flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          
          <h3 class="text-2xl font-bold text-text-main font-heading mb-2">
            <span class="lang-fr">Message Envoyé !</span>
            <span class="lang-en">Message Sent!</span>
          </h3>
          <p class="text-sm text-text-sub max-w-sm leading-relaxed mb-6">
            <span class="lang-fr">Votre demande a bien été enregistrée. Benny Samuel HOUNSOU prendra contact avec vous par e-mail sous 24 heures.</span>
            <span class="lang-en">Your request has been successfully registered. Benny Samuel HOUNSOU will contact you via email within 24 hours.</span>
          </p>

          <button 
            id="reset-form-btn"
            class="flex items-center gap-2 rounded-xl border border-border bg-surface px-5 py-2.5 text-xs font-bold text-text-main hover:bg-border/40 transition-colors cursor-pointer shadow-sm btn-hover"
          >
            <span class="lang-fr">Envoyer un autre message</span>
            <span class="lang-en">Send another message</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // High fidelity client submission handling
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnTextFr = document.getElementById('btn-text-fr');
  const btnTextEn = document.getElementById('btn-text-en');
  const successOverlay = document.getElementById('success-overlay');
  const resetBtn = document.getElementById('reset-form-btn');

  // Set initial placeholders based on lang
  const messageArea = document.getElementById('message') as HTMLTextAreaElement;
  const updatePlaceholder = () => {
    if (messageArea) {
      const currentLang = document.documentElement.getAttribute('data-lang') || 'fr';
      if (currentLang === 'fr') {
        messageArea.placeholder = "Décrivez votre besoin technique ou votre proposition de partenariat...";
      } else {
        messageArea.placeholder = "Describe your technical need or partnership proposal...";
      }
    }
  };

  updatePlaceholder();
  window.addEventListener('lang-changed', updatePlaceholder);

  if (form && submitBtn && successOverlay && resetBtn) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();

      // 1. Enter Loading State
      submitBtn.disabled = true;
      if (btnTextFr) btnTextFr.innerText = "Traitement en cours...";
      if (btnTextEn) btnTextEn.innerText = "Processing...";
      submitBtn.classList.add('opacity-80', 'cursor-not-allowed');

      // 2. Mock network delay
      setTimeout(() => {
        // Show success overlay with dynamic transitions
        successOverlay.classList.remove('hidden');
        setTimeout(() => {
          successOverlay.classList.add('opacity-100');
        }, 50);

        // Reset form content
        form.reset();

        // Restore button state
        submitBtn.disabled = false;
        if (btnTextFr) btnTextFr.innerText = "Envoyer mon message";
        if (btnTextEn) btnTextEn.innerText = "Send my message";
        submitBtn.classList.remove('opacity-80', 'cursor-not-allowed');
      }, 1200);
    });

    // 3. Reset form view handler
    resetBtn.addEventListener('click', () => {
      successOverlay.classList.remove('opacity-100');
      setTimeout(() => {
        successOverlay.classList.add('hidden');
      }, 300);
    });
  }
</script>
